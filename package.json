{
  "name": "fyp-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "load-test:local": "k6 run load-tests/basic-load-test.js",
    "load-test:prod": "k6 run load-tests/basic-load-test.js -e BASE_URL=$PRODUCTION_URL",
    "load-test:stress": "k6 run load-tests/stress-test.js -e BASE_URL=$PRODUCTION_URL",
    "load-test:spike": "k6 run load-tests/spike-test.js -e BASE_URL=$PRODUCTION_URL",
    "load-test:soak": "k6 run load-tests/soak-test.js -e BASE_URL=$PRODUCTION_URL"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.2.2",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^6.21.1",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-webfont-dl": "^3.12.0",
    "vitest": "^4.0.18"
  }
}
